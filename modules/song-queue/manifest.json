{
  "id": "song-queue",
  "name": "Song Queue",
  "version": "1.0.0",
  "min_app_version": "0.1.0",
  "author": "GDLQBot Team",
  "description": "Let viewers request songs or videos to play during your stream.",
  "icon": "music",
  "verified": true,
  "tags": ["official", "music", "queue"],
  "commands": [
    { "trigger": "!sr",          "aliases": [],  "description": "Request a song or video",         "builtin_key": "song_request", "required_badges": [],                          "enabled": true },
    { "trigger": "!nowplaying",  "aliases": [],  "description": "Show the currently playing song", "builtin_key": "now_playing",  "required_badges": [],                          "enabled": true },
    { "trigger": "!playlist",    "aliases": [],  "description": "Show the song request queue",     "builtin_key": "song_list",    "required_badges": [],                          "enabled": true },
    { "trigger": "!skipsong",    "aliases": [],  "description": "Skip to the next song",           "builtin_key": "skip_song",    "required_badges": ["moderator","broadcaster"], "enabled": true }
  ],
  "panels": [
    {
      "id": "songs",
      "label": "Songs",
      "widgets": [
        {
          "widget_type": "Table",
          "columns": [
            { "key": "title",    "label": "Title" },
            { "key": "username", "label": "Requested by" },
            { "key": "added_at", "label": "Time" }
          ],
          "data_expr": "ms.collection(\"queue\").all()",
          "actions": [
            { "label": "Skip", "action_key": "skip_song" }
          ]
        }
      ]
    }
  ],
  "scripts": {
    "song_request": "scripts/request.rhai",
    "now_playing":  "scripts/now_playing.rhai",
    "song_list":    "scripts/list.rhai",
    "skip_song":    "scripts/skip.rhai"
  }
}
