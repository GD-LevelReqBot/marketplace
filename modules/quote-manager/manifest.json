{
  "id": "quote-manager",
  "name": "Quote Manager",
  "version": "1.0.0",
  "min_app_version": "0.1.0",
  "author": "GDLQBot Community",
  "description": "Store and display memorable quotes from your stream.",
  "icon": "custom",
  "verified": false,
  "tags": ["community", "fun", "quotes"],
  "commands": [
    { "trigger": "!quote",    "aliases": [],  "description": "Show a random quote",      "builtin_key": "quote",     "required_badges": [],                          "enabled": true },
    { "trigger": "!addquote", "aliases": [],  "description": "Add a new quote",          "builtin_key": "add_quote", "required_badges": ["moderator","broadcaster"], "enabled": true },
    { "trigger": "!delquote", "aliases": [],  "description": "Delete a quote by number", "builtin_key": "del_quote", "required_badges": ["moderator","broadcaster"], "enabled": true }
  ],
  "panels": [
    {
      "id": "quotes",
      "label": "Quotes",
      "widgets": [
        {
          "widget_type": "Table",
          "columns": [
            { "key": "text",     "label": "Quote" },
            { "key": "added_by", "label": "Added by" },
            { "key": "added_at", "label": "Date" }
          ],
          "data_expr": "ms.collection(\"quotes\").all()",
          "actions": [
            { "label": "Remove", "action_key": "del_quote" }
          ]
        }
      ]
    }
  ],
  "scripts": {
    "quote":     "scripts/quote.rhai",
    "add_quote": "scripts/add_quote.rhai",
    "del_quote": "scripts/del_quote.rhai"
  }
}
